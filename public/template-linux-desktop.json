{
  "$schema": "https://github.com/jiang-zhexin/typebox/releases/latest/download/schema.json",
  "log": {
    "level": "warn",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "type": "tls",
        "tag": "dns-google",
        "detour": "代理",
        "server": "8.8.8.8"
      },
      {
        "type": "dhcp",
        "tag": "dns-local"
      },
      {
        "type": "fakeip",
        "tag": "dns-fakeip",
        "inet4_range": "28.0.0.0/8",
        "inet6_range": "2001:2::/48"
      }
    ],
    "rules": [
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "query_type": "AAAA"
          },
          {
            "default_interface_address": "2000::/3",
            "invert": true
          }
        ],
        "action": "reject"
      },
      {
        "clash_mode": "直连",
        "server": "dns-local"
      },
      {
        "query_type": [
          "SVCB",
          "HTTPS"
        ],
        "action": "predefined",
        "rcode": "NOERROR"
      },
      {
        "rule_set": "domain/ads",
        "action": "predefined",
        "answer": [
          "*.\t3600\tIN\tA\t127.0.0.1",
          "*.\t3600\tIN\tAAAA\t::1"
        ]
      },
      {
        "rule_set": [
          "domain/private",
          "domain/connectivity-check"
        ],
        "server": "dns-local"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "server": "dns-fakeip",
        "rewrite_ttl": 1
      },
      {
        "clash_mode": "全局",
        "server": "dns-google"
      },
      {
        "domain_suffix": [
          ".cm.steampowered.com",
          ".steamserver.net"
        ],
        "rule_set": "domain/china-list",
        "server": "dns-local"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "rule_set": "domain/geolocation-!cn",
            "invert": true
          },
          {
            "rule_set": "ip/cn"
          }
        ],
        "server": "dns-google",
        "client_subnet": "42.159.128.1"
      }
    ],
    "final": "dns-google",
    "independent_cache": true
  },
  "certificate": {
    "store": "mozilla"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "sing-tun",
      "address": [
        "172.19.0.1/30",
        "fdfe:dcba:9876::1/126"
      ],
      "auto_route": true,
      "auto_redirect": true,
      "stack": "mixed"
    },
    {
      "type": "socks",
      "tag": "socks-in",
      "listen": "127.0.0.1",
      "listen_port": 7921
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "直连"
    },
    {
      "type": "selector",
      "tag": "代理",
      "outbounds": [
        "自动"
      ],
      "default": "自动",
      "interrupt_exist_connections": true
    },
    {
      "type": "urltest",
      "tag": "自动",
      "outbounds": null,
      "interrupt_exist_connections": true
    }
  ],
  "route": {
    "rules": [
      {
        "inbound": "socks-in",
        "outbound": "直连"
      },
      {
        "port": 80,
        "rule_set": "ip/telegram",
        "action": "reject",
        "method": "drop"
      },
      {
        "rule_set": "domain/ads",
        "action": "reject"
      },
      {
        "port": 53,
        "action": "hijack-dns"
      },
      {
        "clash_mode": "直连",
        "outbound": "直连"
      },
      {
        "clash_mode": "全局",
        "outbound": "代理"
      },
      {
        "network": "udp",
        "port": 123,
        "outbound": "直连"
      },
      {
        "domain_suffix": [
          ".cm.steampowered.com",
          ".steamserver.net"
        ],
        "rule_set": "domain/china-list",
        "outbound": "直连"
      },
      {
        "network": "udp",
        "port": 443,
        "rule_set": "domain/geolocation-!cn",
        "action": "reject"
      },
      {
        "rule_set": "domain/geolocation-!cn",
        "outbound": "代理"
      },
      {
        "action": "resolve"
      },
      {
        "ip_is_private": true,
        "rule_set": "ip/cn",
        "outbound": "直连"
      },
      {
        "network": "udp",
        "port": 443,
        "action": "reject"
      }
    ],
    "rule_set": [
      {
        "type": "remote",
        "tag": "domain/ads",
        "url": "https://testingcf.jsdelivr.net/gh/cab233/yawgrs@release/geosite-category-ads-all.srs",
        "download_detour": "直连"
      },
      {
        "type": "remote",
        "tag": "domain/china-list",
        "url": "https://testingcf.jsdelivr.net/gh/cab233/yawgrs@release/geosite-geolocation-cn.srs",
        "download_detour": "直连"
      },
      {
        "type": "remote",
        "tag": "domain/geolocation-!cn",
        "url": "https://testingcf.jsdelivr.net/gh/cab233/yawgrs@release/geosite-geolocation-!cn.srs",
        "download_detour": "直连"
      },
      {
        "type": "remote",
        "tag": "domain/private",
        "url": "https://testingcf.jsdelivr.net/gh/cab233/yawgrs@release/geosite-private.srs",
        "download_detour": "直连"
      },
      {
        "type": "remote",
        "tag": "domain/connectivity-check",
        "url": "https://testingcf.jsdelivr.net/gh/cab233/yawgrs@release/geosite-connectivity-check.srs",
        "download_detour": "直连"
      },
      {
        "type": "remote",
        "tag": "ip/cn",
        "url": "https://testingcf.jsdelivr.net/gh/Loyalsoldier/geoip@release/srs/cn.srs",
        "download_detour": "直连"
      },
      {
        "type": "remote",
        "tag": "ip/telegram",
        "url": "https://testingcf.jsdelivr.net/gh/Loyalsoldier/geoip@release/srs/telegram.srs",
        "download_detour": "直连"
      }
    ],
    "final": "代理",
    "find_process": true,
    "auto_detect_interface": true,
    "default_domain_resolver": "dns-local"
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "store_fakeip": true,
      "store_rdrc": true
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "ui",
      "external_ui_download_url": "https://github.com/Zephyruso/zashboard/releases/latest/download/dist-no-fonts.zip",
      "secret": "114514",
      "default_mode": "规则",
      "access_control_allow_origin": "https://board.zash.run.place",
      "access_control_allow_private_network": true
    }
  }
}
